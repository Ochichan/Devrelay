{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevRelay",
  "version": "0.1.0",
  "identifier": "dev.devrelay.desktop",
  "build": {
    "beforeDevCommand": "npm run build:ui",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DevRelay",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "category": "DeveloperTool",
    "shortDescription": "Personal development fabric",
    "longDescription": "DevRelay preserves and transfers verified development sessions between personal machines.",
    "macOS": {
      "frameworks": ["frameworks/libiconv.2.dylib"],
      "signingIdentity": "-",
      "hardenedRuntime": false,
      "minimumSystemVersion": "12.0"
    }
  }
}
